# Copy this file to .env and fill values locally.
# Never commit .env or real API keys.

OPENAI_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
ELEVENLABS_API_KEY=

ASSISTANT_NAME=JARVIS
LLM_MODEL=gpt-4.1-mini
STT_MODEL=whisper-1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=onyx
VOICE_PROVIDER=openai
ELEVENLABS_TTS_ENABLED=false
ELEVENLABS_STT_ENABLED=false
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_SECONDS=20
EMBEDDING_MODEL=text-embedding-3-small

INPUT_MODE=wake
TTS_ENABLED=true
TTS_ASYNC_PLAYBACK=true
RAG_ENABLED=true
AUTO_MEMORY_ENABLED=true
TERMINAL_UI=true
FUNCTION_CALLING_ENABLED=true
DEBUG=false
LOG_LEVEL=INFO

MAX_HISTORY_MESSAGES=40
HISTORY_ENABLED=true
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
MAX_RECORD_SECONDS=12
WAKE_RECORD_SECONDS=4
COMMAND_TIMEOUT_SECONDS=10
AWAKE_CONFIRMATION_TIMEOUT_SECONDS=10
SPEECH_END_SILENCE_SECONDS=0.9
MIN_SILENCE_MS=650
AUDIO_CHUNK_SECONDS=0.2
MICROPHONE_SENSITIVITY=normal
SPEECH_RMS_THRESHOLD=500
MIN_SPEECH_SECONDS=0.35
SAMPLE_RATE=16000
STT_LANGUAGE=pl
STT_PROMPT=Rozmowa po polsku z asystentem technicznym JARVIS.
TRANSCRIPT_CORRECTION_ENABLED=true
TRANSCRIPT_CORRECTION_WITH_LLM=false
TRANSCRIPT_CORRECTION_MIN_CONFIDENCE=0.65
WAKE_PHRASE=jarvis śpisz?

HISTORY_PATH=data/conversation_history.json
LONG_TERM_MEMORY_PATH=data/long_term_memory.json
DOCUMENTS_DIR=data/documents
VECTOR_STORE_DIR=data/vector_store
TTS_OUTPUT_PATH=data/tts_output.mp3
MICROPHONE_TEMP_PATH=data/mic_input.wav
USER_PROFILE_PATH=data/user_profile.json
TASK_STORE_PATH=data/tasks.json
PROJECT_STORE_PATH=data/projects.json
ASSISTANT_STATE_PATH=data/assistant_state.json
TOOL_CALL_LOG_PATH=data/tool_calls.json
CONVERSATION_SUMMARY_PATH=data/conversation_summary.json
EPISODIC_MEMORY_PATH=data/episodic_memory.json
COST_LOG_PATH=data/usage_costs.json
FEEDBACK_PATH=data/feedback.json
CHROMA_COLLECTION=jarvis_memory

LOW_LATENCY_MODE=true
STREAMING_LLM=true
STREAMING_TTS=true
POST_SPEECH_SLEEP_DELAY_SECONDS=5.0
RESPONSE_TEXT_CLEAR_DELAY_SECONDS=1.0
FOLLOW_UP_TIMEOUT_SECONDS=10
GPT_4_1_MINI_INPUT_COST_PER_1M=0.40
GPT_4_1_MINI_OUTPUT_COST_PER_1M=1.60
LATENCY_BUDGET_SECONDS=2.0
LATENCY_CRITICAL_SECONDS=3.0
CHUNK_MS=450
AVG_RTT_MS=900
TOKENS_PER_S=40

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT=5.0
WEB_SEARCH_RESULT_LIMIT=8
WEB_SEARCH_FRESHNESS_DAYS=7
WEB_SEARCH_CACHE_ENABLED=true
WEB_SEARCH_CACHE_PATH=data/search_cache.json
WEB_SEARCH_CACHE_TTL_SECONDS=900
RESEARCH_TRACE_PATH=data/research_traces.json

JARVIS_PRIMARY_SEARCH=tavily
JARVIS_FALLBACK_SEARCH=brave
JARVIS_ENABLE_REALTIME_SEARCH=true
JARVIS_ENABLE_BRAVE_FALLBACK=false
STRICT_RETRIEVAL=true
RETRIEVAL_TRACE_PATH=data/retrieval_traces.jsonl
JARVIS_CACHE_DIR=.cache/jarvis
JARVIS_TIMEZONE=Europe/Warsaw
JARVIS_SEARCH_MAX_RESULTS=6
JARVIS_SEARCH_TIMEOUT_SECONDS=15
JARVIS_FETCH_TIMEOUT_SECONDS=20
JARVIS_RERANK_TOP_K=5
JARVIS_HUD_ANIMATIONS_ENABLED=true

LLM_VALIDATOR_ENABLED=false
LLM_VALIDATOR_MODEL=gpt-4.1-mini
LLM_VALIDATOR_MAX_SOURCES=6
LLM_VALIDATOR_MIN_CONFIDENCE=0.72
LLM_VALIDATOR_VALIDATE_IMAGES=true
LLM_VALIDATOR_VALIDATE_REPORTS=true
LLM_VALIDATOR_VALIDATE_VIDEOS=true
