# Archives and database dumps.
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.sql
*.dump
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# Generated project graph output. Can include derived Obsidian/workspace metadata
# and snapshots of local runtime files, so keep it local unless intentionally shared.
graphify-out/

# Runtime cache and private local state.
.cache/
data/*
!data/documents/
data/documents/**
!data/documents/.gitkeep
!data/vector_store/
data/vector_store/**
!data/vector_store/.gitkeep

# Runtime audio and generated media.
data/**/*.wav
data/**/*.mp3
data/**/*.m4a
data/**/*.ogg
